{
  "name": "zk-whistleblower",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "compile:circuit": "tsx scripts/compile-circuit.ts",
    "test": "npx hardhat test mocha",
    "register": "npx hardhat run scripts/register-members.ts",
    "configure:relayer": "npx hardhat run scripts/configure-relayer-admin.ts",
    "decrypt": "npx tsx scripts/decrypt-secret.ts",
    "deploy:local": "npx hardhat run --network localhost scripts/deploy.ts",
    "deploy:sepolia": "npx hardhat run --network sepolia scripts/deploy.ts",
    "db:generate": "pnpm --filter @zk-whistleblower/db prisma generate",
    "db:migrate": "pnpm --filter @zk-whistleblower/db prisma migrate dev",
    "db:deploy": "pnpm --filter @zk-whistleblower/db prisma migrate deploy",
    "dev:admin": "pnpm --filter @zk-whistleblower/admin dev",
    "dev:reporter": "pnpm --filter @zk-whistleblower/reporter dev",
    "dev": "pnpm -r dev",
    "build": "pnpm -r build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.18.2",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.3",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "chai": "^6.2.2",
    "circomlibjs": "^0.1.7",
    "ethers": "^6.16.0",
    "hardhat": "^3.1.11",
    "mocha": "^11.7.5",
    "snarkjs": "^0.7.6",
    "tsx": "^4.20.5",
    "typescript": "~5.8.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1"
  },
  "pnpm": {
    "overrides": {
      "wagmi": "2.19.5",
      "viem": "2.47.0",
      "@tanstack/react-query": "^5.91.3"
    },
    "ignoredBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  },
  "type": "module"
}