generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  output        = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageSender {
  ADMIN
  REPORTER
}

enum MessageDeliveryState {
  QUEUED
  DELIVERED
  READ
}

enum ThreadStatus {
  ACTIVE
  ARCHIVED
}

enum ConsensusStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  ESCALATED
  TIMEOUT
}

enum AdminVote {
  APPROVE
  REJECT
  ESCALATE
  ABSTAIN
}

model MessageThread {
  id            String   @id
  status        ThreadStatus @default(ACTIVE)
  lastMessageAt DateTime @default(now())
  archivedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages Message[]

  @@index([status, lastMessageAt])
}

model Message {
  id         String   @id @default(cuid())
  threadId   String
  thread     MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender     MessageSender
  nonce      String
  ciphertext String
  timestamp  DateTime
  deliveryState MessageDeliveryState @default(DELIVERED)
  deliveredAt DateTime @default(now())
  readAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([threadId, timestamp])
  @@index([sender, timestamp])
  @@index([deliveryState, timestamp])
}

model ReportConsensusRequest {
  id             String          @id @default(cuid())
  onChainReportId BigInt?
  reporterThreadId String?
  selectedAdmins  String[]        @default([])
  status          ConsensusStatus @default(PENDING_REVIEW)
  metadata        Json?
  createdAt       DateTime        @default(now())
  decidedAt       DateTime?

  votes AdminConsensusVote[]
  decision AdminDecision?

  @@index([onChainReportId])
  @@index([status, createdAt])
}

model AdminConsensusVote {
  id                    String    @id @default(cuid())
  consensusRequestId    String
  consensusRequest      ReportConsensusRequest @relation(fields: [consensusRequestId], references: [id], onDelete: Cascade)
  adminAddress          String
  vote                  AdminVote
  reason                String?
  encryptedReason       String?
  votedAt               DateTime  @default(now())
  signature             String?

  @@index([consensusRequestId, adminAddress])
  @@index([adminAddress, votedAt])
}

model AdminDecision {
  id                  String   @id @default(cuid())
  consensusRequestId  String   @unique
  consensusRequest    ReportConsensusRequest @relation(fields: [consensusRequestId], references: [id], onDelete: Cascade)
  action              String
  actionMetadata      Json?
  decidedByConsensus  Int?
  executedAt          DateTime?
  executedBy          String?
}